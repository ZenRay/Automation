# Environment variables for container deployment
# Copy this file to .env and fill in the values

# GHCR repository path (e.g., org/automation)
GHCR_REPO=

# Image tag to deploy (e.g., sha-abc1234, v1.0.0, staging, production)
IMAGE_TAG=

# Full image reference (overrides GHCR_REPO + IMAGE_TAG)
# For local testing: IMAGE=localhost/automation:test
# For GHCR: IMAGE=ghcr.io/org/automation:sha-abc1234
IMAGE=

# Host path to .ini configuration files
CONFIG_DIR=/opt/automation/config

# Scheduler interval in seconds (default: 3600 = 1 hour)
SCHEDULE_INTERVAL=3600
